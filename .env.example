# ── Django ──────────────────────────────────────────────────────────────────
DJANGO_SETTINGS_MODULE=config.settings.production
SECRET_KEY=change-me-in-production-use-50-random-chars

# ── Database (PostgreSQL) ────────────────────────────────────────────────────
DB_NAME=droproom
DB_USER=droproom
DB_PASSWORD=strong-password-here
DB_HOST=db
DB_PORT=5432

# Docker Compose env vars (used in compose file directly)
POSTGRES_DB=droproom
POSTGRES_USER=droproom
POSTGRES_PASSWORD=strong-password-here

# ── Hosts & CSRF ─────────────────────────────────────────────────────────────
# HTTP (first deploy):
ALLOWED_HOSTS=your-server-ip,localhost,127.0.0.1,web
CSRF_TRUSTED_ORIGINS=http://your-server-ip

# HTTPS (production):
ALLOWED_HOSTS=droproom.com.ua,www.droproom.com.ua,67.205.166.155,localhost,127.0.0.1,web
CSRF_TRUSTED_ORIGINS=https://droproom.com.ua,https://www.droproom.com.ua

# ── SSL ──────────────────────────────────────────────────────────────────────
# Always False inside Docker — nginx handles the redirect
SECURE_SSL_REDIRECT=False
