# ── Django ──────────────────────────────────────────────────────────────────
DJANGO_SETTINGS_MODULE=config.settings.production
SECRET_KEY=change-me-in-production-use-50-random-chars

# ── Database (PostgreSQL) ────────────────────────────────────────────────────
DB_NAME=droproom
DB_USER=droproom
DB_PASSWORD=strong-password-here
DB_HOST=db
DB_PORT=5432

# Docker Compose env vars (used in compose file directly)
POSTGRES_DB=droproom
POSTGRES_USER=droproom
POSTGRES_PASSWORD=strong-password-here

# ── Hosts & CSRF ─────────────────────────────────────────────────────────────
# HTTP (first deploy):
ALLOWED_HOSTS=your-server-ip,localhost,127.0.0.1,web
CSRF_TRUSTED_ORIGINS=http://your-server-ip

# HTTPS (production):
ALLOWED_HOSTS=droproom.com.ua,www.droproom.com.ua,67.205.166.155,localhost,127.0.0.1,web
CSRF_TRUSTED_ORIGINS=https://droproom.com.ua,https://www.droproom.com.ua

# ── SSL ──────────────────────────────────────────────────────────────────────
# Always False inside Docker — nginx handles the redirect
SECURE_SSL_REDIRECT=False

# ── Telegram import ────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=generate-random-secret-here
TELEGRAM_WEBHOOK_URL=https://droproom.com.ua/telegram/webhook/
# ID каналу (напр. -1001234567890). 0 = приймати з будь-якого каналу
TELEGRAM_CHANNEL_ID=0
# Дефолти для товарів без повного опису в пості
TELEGRAM_DEFAULT_BRAND_ID=0
TELEGRAM_DEFAULT_CATEGORY_ID=0
TELEGRAM_DEFAULT_GENDER=U
TELEGRAM_DEFAULT_PRICE=1000
TELEGRAM_DEFAULT_SIZE=ONE SIZE
TELEGRAM_DEFAULT_STOCK=1
# False = товар імпортується неактивним, перевірка в адмінці
TELEGRAM_IMPORT_AS_ACTIVE=False

# ── Telethon (історія каналу + cron sync) ─────────────────────────────────────
# Отримати на https://my.telegram.org → API development tools
TELEGRAM_API_ID=0
TELEGRAM_API_HASH=
# Згенерувати: python3 manage.py telegram_login
TELEGRAM_SESSION_STRING=
# Публічний канал: @my_channel або my_channel
TELEGRAM_CHANNEL_USERNAME=

# ── Імпорт старих постів (без Telethon) ───────────────────────────────────────
# Telegram Desktop → канал → Export chat history → JSON
# python3 manage.py import_telegram_export /шлях/до/папки_експорту
